/* FlowCap — Minimal dark theme */

* {
    outline: none;
}

QWidget {
    background-color: #0e0e0e;
    color: #e8e8e8;
    font-family: "Helvetica Neue", "Segoe UI", Arial, sans-serif;
    font-size: 13px;
}

QMainWindow, QDialog {
    background-color: #0e0e0e;
}

/* ── Group boxes ────────────────────────────────────────────────────── */
QGroupBox {
    border: none;
    border-top: 1px solid #1f1f1f;
    border-radius: 0;
    margin-top: 18px;
    padding-top: 14px;
    color: #444;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 0px;
    padding: 0 6px 0 0;
}

/* ── Drop zone ─────────────────────────────────────────────────────── */
#dropZone {
    background-color: #161622;
    border: 1.5px dashed #3d3d6b;
    border-radius: 10px;
    color: #888;
    font-size: 13px;
    min-height: 110px;
}

#dropZone:hover {
    border-color: #6366f1;
    background-color: #141420;
}

#dropZone[success="true"] {
    border-color: #34d399;
    background-color: #0e1f18;
}

/* ── Buttons ────────────────────────────────────────────────────────── */
QPushButton {
    background-color: #222222;
    color: #aaa;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 7px 18px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1px;
}

QPushButton:hover {
    background-color: #2c2c2c;
    color: #eee;
    border-color: #555;
}

QPushButton:pressed {
    background-color: #1a1a1a;
    color: #ccc;
    border-color: #333;
}

QPushButton:disabled {
    background-color: #161616;
    color: #2a2a2a;
    border-color: #1e1e1e;
}

/* ── Convert / primary action button ───────────────────────────────── */
#convertBtn {
    background-color: #5c5ff0;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 9px 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
}

#convertBtn:hover {
    background-color: #6e71f5;
}

#convertBtn:pressed {
    background-color: #4a4dd4;
}

#convertBtn:disabled {
    background-color: #1e1e38;
    color: #3a3a60;
}

/* ── Open folder button ─────────────────────────────────────────────── */
#openFolderBtn {
    background-color: transparent;
    color: #34d399;
    border: 1px solid #1e4d3a;
    border-radius: 6px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 500;
}

#openFolderBtn:hover {
    background-color: #0d2a20;
    border-color: #34d399;
}

/* ── Progress bar ───────────────────────────────────────────────────── */
QProgressBar {
    background-color: #1a1a1a;
    border: none;
    border-radius: 3px;
    height: 4px;
    max-height: 4px;
}

QProgressBar::chunk {
    background-color: #6366f1;
    border-radius: 3px;
}

/* ── Log console ────────────────────────────────────────────────────── */
#logConsole {
    background-color: #0a0a0a;
    color: #5a8a5a;
    border: none;
    border-top: 1px solid #1a1a1a;
    border-radius: 0;
    font-family: ui-monospace, "SF Mono", "Fira Code", "Consolas", monospace;
    font-size: 11px;
    padding: 8px 4px;
}

/* ── Labels ─────────────────────────────────────────────────────────── */
QLabel#titleLabel {
    color: #f0f0f0;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
}

QLabel#subtitleLabel {
    color: #3a3a3a;
    font-size: 11px;
    letter-spacing: 0.2px;
}

QLabel#filenameLabel {
    color: #d0d0d0;
    font-size: 13px;
    font-weight: 600;
}

QLabel#infoLabel {
    color: #555;
    font-size: 11px;
    background-color: transparent;
    border: none;
    padding: 0;
}

QLabel#sectionLabel {
    color: #444;
    font-size: 11px;
}

QLabel#doneLabel {
    color: #34d399;
    font-size: 12px;
    font-weight: 500;
}

QLabel#errorLabel {
    color: #f87171;
    font-size: 11px;
    background-color: #1a0a0a;
    border: 1px solid #3a1515;
    border-radius: 4px;
    padding: 6px 10px;
}

/* ── Thumbnail frame ────────────────────────────────────────────────── */
#thumbnailFrame {
    background-color: #141414;
    border: 1px solid #222;
    border-radius: 6px;
}

/* ── ComboBox ───────────────────────────────────────────────────────── */
QComboBox {
    background-color: #1e1e1e;
    color: #bbb;
    border: 1px solid #2e2e2e;
    border-radius: 6px;
    padding: 5px 10px;
    min-width: 160px;
    font-size: 12px;
}

QComboBox:hover {
    border-color: #444;
    color: #e8e8e8;
}

QComboBox::drop-down {
    border: none;
    width: 18px;
}

QComboBox QAbstractItemView {
    background-color: #1e1e1e;
    color: #bbb;
    border: 1px solid #2e2e2e;
    border-radius: 6px;
    selection-background-color: #5c5ff0;
    selection-color: #fff;
}

/* ── Scrollbars ─────────────────────────────────────────────────────── */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
}

QScrollBar::handle:vertical {
    background: #2a2a2a;
    border-radius: 3px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #3a3a3a;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    height: 6px;
    background: transparent;
}

QScrollBar::handle:horizontal {
    background: #2a2a2a;
    border-radius: 3px;
}

/* ── Credit ─────────────────────────────────────────────────────────── */
QLabel#creditLabel {
    color: #333;
    font-size: 11px;
    padding-top: 8px;
    margin-left: -4px;
}

QLabel#creditLabel:hover {
    color: #666;
}

/* ── Tooltip ────────────────────────────────────────────────────────── */
QToolTip {
    background-color: #1e1e1e;
    color: #e8e8e8;
    border: 1px solid #2e2e2e;
    border-radius: 6px;
    padding: 4px 8px;
}
